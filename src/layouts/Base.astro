---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Mu Alpha Theta — instilling excellence in math while using it to serve others. Student-led coaching for UMTYMP and Math Masters, with proceeds supporting underprivileged children in India.' } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/program/', label: 'Our Program' },
  { href: '/achievements/', label: 'Achievements' },
  { href: '/story/', label: 'Our Story' },
  { href: '/testimonials/', label: 'Testimonials' },
  { href: '/support/', label: 'Support' },
  { href: '/contact/', label: 'Contact' },
];

const path = Astro.url.pathname;
const isCurrent = (href: string) => path === href;
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(path, Astro.site)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#7A2231" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <nav class="wrap nav" aria-label="Primary">
        <a class="brand" href="/">
          <span class="mark" aria-hidden="true">μαθ</span>
          <span>Mu Alpha Theta</span>
        </a>
        <input type="checkbox" id="nav-toggle" class="sr-only" aria-label="Toggle navigation menu" />
        <label for="nav-toggle" class="btn btn--ghost nav-toggle">Menu</label>
        <ul class="nav-links">
          {nav.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid grid--2" style="align-items:start;">
          <div>
            <a class="brand" href="/" style="color:#fff;">
              <span class="mark" aria-hidden="true">μαθ</span>
              <span>Mu Alpha Theta</span>
            </a>
            <p class="muted" style="margin-top:1rem; max-width:40ch;">
              Math Without Borders — excellence in mathematics, in service of others.
            </p>
          </div>
          <div>
            <p style="margin:0 0 .25rem;"><strong>Get in touch</strong></p>
            <p class="muted" style="margin:0;">
              <a href="mailto:mualphatheta@gmail.com">mualphatheta@gmail.com</a><br />
              Eagan, Minnesota
            </p>
          </div>
        </div>
        <hr class="divider" style="background:#3A383C; margin-block:2rem;" />
        <p class="muted" style="margin:0; font-size:var(--step--1);">
          © {year} Mu Alpha Theta · A student-led initiative · Eagan, MN
        </p>
      </div>
    </footer>
  </body>
</html>
