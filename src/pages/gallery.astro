---
import Base from '../layouts/Base.astro';
import { Image, getImage } from 'astro:assets';

// Auto-import every photo in src/assets/photos/ — drop new images there and
// they appear here automatically. Files 01–26 are Grade Five, 27–33 Grade Four.
const modules = import.meta.glob('../assets/photos/*.{jpg,jpeg,png}', { eager: true });
const entries = Object.entries(modules).sort(([a], [b]) => a.localeCompare(b));

const photos = await Promise.all(
  entries.map(async ([path, mod], i) => {
    const src = mod.default;
    const full = await getImage({ src, width: 1600, format: 'webp' });
    const grade = i < 26 ? 'Grade Five' : 'Grade Four';
    return { src, full: full.src, alt: `${grade} team — Math Masters 2026` };
  })
);
---

<Base title="Gallery — Mu Alpha Theta" description="Photos from our Glacier Hills students' Math Masters 2026 journey — coaching sessions, competition day, medals, and team celebrations.">
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Gallery</p>
      <h1 style="max-width: 20ch;">Moments from the journey.</h1>
      <p class="lead">
        From quiet coaching sessions to competition day — every photo here is a step our
        Grade Five and Grade Four students took together. Tap any image to view it full size.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <div class="gallery-grid">
        {photos.map((p, i) => (
          <button class="gallery-item" type="button" data-full={p.full} aria-label={`View photo ${i + 1} of ${photos.length}`}>
            <Image src={p.src} alt={p.alt} widths={[320, 640]} sizes="(max-width: 600px) 50vw, (max-width: 1000px) 33vw, 25vw" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <div id="lightbox" class="lightbox" hidden>
    <button class="lightbox__close" type="button" aria-label="Close">&times;</button>
    <img class="lightbox__img" src="" alt="" />
  </div>
</Base>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.85rem;
  }
  .gallery-item {
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
    line-height: 0;
  }
  .gallery-item :global(img) {
    display: block;
    width: 100%;
    height: 230px;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .gallery-item:hover :global(img) { transform: scale(1.05); }
  .gallery-item:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(20, 15, 17, 0.92);
  }
  .lightbox[hidden] { display: none; }
  .lightbox__img {
    max-width: 92vw;
    max-height: 88vh;
    border-radius: 8px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.5);
  }
  .lightbox__close {
    position: absolute;
    top: 0.75rem;
    right: 1.5rem;
    font-size: 2.75rem;
    line-height: 1;
    color: #fff;
    background: none;
    border: 0;
    cursor: pointer;
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  if (lb) {
    const lbImg = lb.querySelector('.lightbox__img');
    const closeBtn = lb.querySelector('.lightbox__close');

    const open = (full, alt) => {
      lbImg.src = full;
      lbImg.alt = alt;
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lb.hidden = true;
      lbImg.src = '';
      document.body.style.overflow = '';
    };

    document.querySelectorAll('.gallery-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const img = btn.querySelector('img');
        open(btn.dataset.full, img ? img.alt : '');
      });
    });
    closeBtn.addEventListener('click', close);
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !lb.hidden) close(); });
  }
</script>
