---
import Base from '../layouts/Base.astro';

const enrollmentForm = 'https://forms.gle/dFWTknm6hXb7Jhd39';
const volunteerForm = 'https://forms.gle/dFWTknm6hXb7Jhd39';
---

<Base title="Contact — Mu Alpha Theta" description="Enroll a student, volunteer as a coach, or ask about supporting our cause. Reach the Eagan chapter of Mu Alpha Theta.">
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Contact</p>
      <h1 style="max-width: 20ch;">Let's get started.</h1>
      <p class="lead">
        Whether you'd like to enroll a young mathematician, volunteer as a coach, or support
        the cause, we'd love to hear from you.
      </p>
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="wrap grid grid--3">
      <div class="card">
        <h3>Enroll a student</h3>
        <p>For elementary and middle school students preparing for UMTYMP or Math Masters.</p>
        <p class="mt-0"><a href={enrollmentForm} target="_blank" rel="noopener">Sign up as a student →</a></p>
      </div>
      <div class="card">
        <h3>Volunteer to coach</h3>
        <p>High school students strong in math who want to teach and mentor.</p>
        <p class="mt-0"><a href={volunteerForm} target="_blank" rel="noopener">Sign up as a volunteer →</a></p>
      </div>
      <div class="card">
        <h3>Support the cause</h3>
        <p>Learn how optional donations help children in India.</p>
        <p class="mt-0"><a href="mailto:mualphatheta@gmail.com?subject=Supporting%20the%20cause">Email to give →</a></p>
      </div>
    </div>

    <div class="wrap" style="padding-inline:0; margin-top:3rem;">
      <p class="eyebrow">Reach us directly</p>
      <p style="font-size:var(--step-1); margin-bottom:0.25rem;">
        <a href="mailto:mualphatheta@gmail.com">mualphatheta@gmail.com</a>
      </p>
      <p class="lead" style="margin-bottom:0;">4185 Braddock Trail, Eagan, MN 55123</p>
    </div>
  </section>
</Base>
